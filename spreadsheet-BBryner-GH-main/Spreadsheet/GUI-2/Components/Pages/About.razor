<!-- About page  -->

<PageTitle>About - Spreadsheet</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-4">
                <h1>Spreadsheet</h1>
                <p class="lead">By Brenden Bryner</p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h3 class="card-title">Supported Cell Inputs</h3>
                    <ul class="list-unstyled">
                        <p>To enter data just click on a cell, see the cell name box change to the selected cell, and type the value inside the cell contents
                            text box and press enter.</p>
                        <li><strong>Numbers:</strong> 5, 5.0 -5</li>
                        <li><strong>Text:</strong> Any string (basic text)</li>
                        <li><strong>Formulas:</strong> Start with "=" (example: =A1+B2)</li>
                    </ul>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h3 class="card-title">Extra Feature</h3>
                    <p class="card-text">
                        <strong>Formula preview window:</strong> As the formulas are typed, there is a popup window that displays what will be displayed by the formula in hopes to get rid of errors. Works like how it would in google sheets or excel.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>